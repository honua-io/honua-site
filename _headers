/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://honua.io; form-action 'self' https://formsubmit.co; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# /demo.html is the only page that talks to the live demo Honua Server and runs
# MapLibre GL (blob: web workers). The extra origins/directives are scoped to
# this path only; every other page keeps the strict policy above. Keep this in
# sync with the <meta http-equiv="Content-Security-Policy"> tag in demo.html
# (GitHub Pages ignores _headers, so the meta tag is the enforced copy there).
/demo.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://demo.honua.io https://www.google-analytics.com https://region1.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://www.google-analytics.com https://honua.io; worker-src blob:; child-src blob:; form-action 'self' https://formsubmit.co; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# /excel-addin/* hosts the "Honua for Excel" taskpane (Office.js add-in). It
# must load Office.js from Microsoft's CDN, call the live demo Honua Server,
# and — unlike every other page — be frameable: Excel on the web renders
# taskpanes inside Office-hosted iframes. So this path allows Office frame
# ancestors instead of 'none' and deliberately omits X-Frame-Options (which
# cannot express an allowlist). Keep in sync with the
# <meta http-equiv="Content-Security-Policy"> tag in excel-addin/taskpane.html
# (GitHub Pages ignores _headers, so the meta tag is the enforced copy there;
# meta CSP cannot carry frame-ancestors, which keeps the pane embeddable).
/excel-addin/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors https://*.cloud.microsoft https://*.office.com https://*.officeapps.live.com; script-src 'self' https://appsforoffice.microsoft.com; connect-src 'self' https://demo.honua.io; frame-src 'self' https://telemetryservice.firstpartyapps.oaspapps.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://honua.io; form-action 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
